# ── Environment ───────────────────────────────────────
NODE_ENV=development                    # development | staging | production

# ── Supabase / PostgreSQL ─────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-key

# ── ClickHouse (Analytics OLAP) ───────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=tokenforge
CLICKHOUSE_PASSWORD=                    # Required in production

# ── Redis (Cache + Rate Limiting) ─────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=                         # Required in production

# ── Security ──────────────────────────────────────────
ENCRYPTION_KEY=                         # 64-char hex string: openssl rand -hex 32
ALLOWED_ORIGINS=http://localhost:3000   # Comma-separated origins for CORS

# ── Proxy API ─────────────────────────────────────────
PROXY_PORT=8787
LOG_LEVEL=info                          # debug | info | warn | error

# ── Web App ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8787/api

# ── AI Providers (optional - orgs can configure their own) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GOOGLE_AI_KEY=

# ── Stripe (Billing) ─────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Docker Compose Production ─────────────────────────
POSTGRES_PASSWORD=changeme_in_production
