# ────────────────────────────────────────────────────────────
#  Octroi — production environment (managed cloud)
#  Proxy secrets → Fly.io (`fly secrets set ...`)
#  Web public vars → Vercel project env
# ────────────────────────────────────────────────────────────
NODE_ENV=production

# ── PostgreSQL (Supabase) ──────────────────────────────────
# Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<REF>.supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://<REF>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<SERVICE_ROLE_KEY>

# ── Redis (Upstash) ────────────────────────────────────────
# Upstash → database → "Redis URL" (rediss:// with embedded auth)
REDIS_URL=rediss://default:<PASSWORD>@<HOST>.upstash.io:6379

# ── ClickHouse Cloud ───────────────────────────────────────
CLICKHOUSE_URL=https://<ID>.<REGION>.clickhouse.cloud:8443
CLICKHOUSE_DB=tokenforge
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=<PASSWORD>

# ── Security ───────────────────────────────────────────────
ENCRYPTION_KEY=<openssl rand -hex 32>
ALLOWED_ORIGINS=https://app.octroi.io

# ── Web (Vercel) — points at the Fly proxy ─────────────────
NEXT_PUBLIC_APP_URL=https://app.octroi.io
NEXT_PUBLIC_API_URL=https://octroi-proxy.fly.dev/api

# ── AI providers (optional global fallbacks) ───────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GOOGLE_AI_KEY=
